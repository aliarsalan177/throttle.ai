{
  "name": "tokens-reducer",
  "version": "0.0.0",
  "private": true,
  "description": "Token Reduction Engine — transparent local proxy that cuts LLM token cost without degrading context quality.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r --no-bail test:coverage",
    "dev:proxy": "pnpm --filter @tre/proxy dev",
    "smoke": "node scripts/smoke.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "2.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
