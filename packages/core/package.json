{
  "name": "@tre/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Provider-agnostic token-reduction pipeline (pure, no I/O).",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "diff": "^7.0.0",
    "gpt-tokenizer": "^2.8.1"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
